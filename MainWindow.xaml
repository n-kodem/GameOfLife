<Window x:Class="GameOfLife.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GameOfLife"
        xmlns:vm="clr-namespace:GameOfLife.ViewModels"
        xmlns:views="clr-namespace:GameOfLife.Views"
        mc:Ignorable="d"
        Title="Laboratorium 3 - Nikodem Reszka" Height="800" Width="1200"
        Background="#F0F0F0">
    
    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        
        <Style TargetType="Button">
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E0E0E0"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Górny pasek narzędzi -->
        <ToolBar Grid.Row="0">
            <Button Command="{Binding StartCommand}" Content="▶ Start" Foreground="Green" ToolTip="Uruchamia ciągłą animację automatu."/>
            <Button Command="{Binding StopCommand}" Content="⏸ Pauza" Foreground="Red" ToolTip="Zatrzymuje animację."/>
            <Button Command="{Binding StepCommand}" Content="⏭ Krok" ToolTip="Wykonuje pojedynczy krok symulacji."/>
            <Separator/>
            <Button Command="{Binding ClearCommand}" Content="🗑 Wyczyść" ToolTip="Czyści całą planszę (wszystkie komórki umierają)."/>
            <Button Command="{Binding RandomizeCommand}" Content="🎲 Losuj" ToolTip="Wypełnia planszę losowo żywymi komórkami."/>
            <Separator/>
            <Button Command="{Binding SaveCommand}" Content="💾 Zapisz" ToolTip="Zapisuje obecny stan planszy do pliku JSON."/>
            <Button Command="{Binding LoadCommand}" Content="📂 Wczytaj" ToolTip="Wczytuje stan planszy z pliku JSON."/>
            <Button Command="{Binding ExportImageCommand}" Content="🖼 Eksportuj obraz" ToolTip="Eksportuje widok planszy do pliku graficznego PNG."/>
            <Separator/>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="5,0" ToolTip="Regulacja prędkości animacji (opóźnienie w ms).">
                <TextBlock Text="Prędkość: " VerticalAlignment="Center"/>
                <Slider Minimum="10" Maximum="1000" Value="{Binding Delay}" Width="100" IsDirectionReversed="True"/>
            </StackPanel>
            <Separator/>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="5,0" ToolTip="Zmiana powiększenia planszy.">
                <TextBlock Text="Zoom: " VerticalAlignment="Center"/>
                <Slider Minimum="1" Maximum="50" Value="{Binding Zoom}" Width="100"/>
            </StackPanel>
            <CheckBox IsChecked="{Binding UseCircles}" Content="Kółka" VerticalAlignment="Center" Margin="5,0" ToolTip="Zmienia kształt komórek z kwadratów na koła."/>
        </ToolBar>

        <!-- Główny obszar -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Panel boczny -->
            <StackPanel Grid.Column="0" Background="White" Margin="5">
                <GroupBox Header="Ustawienia siatki" Margin="5">
                    <StackPanel>
                        <TextBlock Text="Topologia:" ToolTip="Wybór siatki automatu (Kwadratowa, Sześciokątna)."/>
                        <ComboBox ItemsSource="{Binding Topologies}" SelectedItem="{Binding SelectedTopology}"/>
                        
                        <TextBlock Text="Model kolorowania:" Margin="0,5,0,0" ToolTip="Model kolorowania: Standard (1 kolor), Immigration (2 kolory), QuadLife (4 kolory)."/>
                        <ComboBox ItemsSource="{Binding ColoringModels}" SelectedItem="{Binding SelectedColoring}"/>
                        
                        <TextBlock Text="Szerokość:" Margin="0,5,0,0" ToolTip="Szerokość planszy w komórkach."/>
                        <TextBox Text="{Binding BoardWidth}"/>
                        
                        <TextBlock Text="Wysokość:" Margin="0,5,0,0" ToolTip="Wysokość planszy w komórkach."/>
                        <TextBox Text="{Binding BoardHeight}"/>
                        
                        <Button Command="{Binding NewBoardCommand}" Content="Stwórz nową planszę" Margin="0,10,0,0" ToolTip="Tworzy nową, pustą planszę o zadanych wymiarach i topologii."/>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="Reguły (B/S)" Margin="5" ToolTip="Konfiguracja reguł: B(Liczba sąsiadów do narodzin) / S(Liczba sąsiadów do przeżycia).">
                    <TextBox Text="{Binding RuleString, UpdateSourceTrigger=PropertyChanged}"/>
                </GroupBox>

                <GroupBox Header="Statystyki" Margin="5">
                    <StackPanel>
                        <TextBlock Text="{Binding Stats.Generations, StringFormat='Pokolenia: {0}', NotifyOnTargetUpdated=True}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <EventTrigger RoutedEvent="Binding.TargetUpdated">
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0.5" To="1" Duration="0:0:0.2"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Text="{Binding Stats.CellsBorn, StringFormat='Urodzone: {0}'}"/>
                        <TextBlock Text="{Binding Stats.CellsDied, StringFormat='Umarłe: {0}'}"/>
                        <TextBlock Text="{Binding Stats.AliveCount, StringFormat='Żywe: {0}'}"/>
                    </StackPanel>
                </GroupBox>
            </StackPanel>

            <!-- Widok siatki -->
            <ScrollViewer Grid.Column="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                <views:GridCanvas x:Name="MainCanvas"
                                  Grid="{Binding Grid}" 
                                  RefreshCounter="{Binding RefreshCounter}"
                                  CellSize="{Binding Zoom}" 
                                  UseCircles="{Binding UseCircles}"/>
            </ScrollViewer>
        </Grid>

        <!-- Pasek stanu -->
        <StatusBar Grid.Row="2">
            <StatusBarItem>
                <TextBlock Text="Gotowy"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
